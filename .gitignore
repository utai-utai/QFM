# === QFM 项目核心配置 ===

# 1. data/raw_images: 忽略里面的图片，但保留文件夹本身
data/raw_images/*
!data/raw_images/.gitkeep

# 2. data/processed: 忽略里面的 .pt，但保留文件夹本身
data/processed/*
!data/processed/.gitkeep

# 3. checkpoints: 忽略里面的 .pth，但保留文件夹本身
checkpoints/*
!checkpoints/.gitkeep

# 4. 保留 data.jsonl
!data/data.jsonl

# === 忽略临时生成的图片 ===
*.png
*.jpg
result.png

# === 日志 ===
*.log
